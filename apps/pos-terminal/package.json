{
  "name": "@gelato/pos-terminal",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build:electron": "electron-vite build",
    "package": "electron-vite build && electron-builder --dir",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@gelato/compliance": "workspace:*",
    "@gelato/domain": "workspace:*",
    "@gelato/sync": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "build": {
    "appId": "com.gelatocore.kasse",
    "productName": "gelato-core Kasse",
    "directories": { "output": "release" },
    "files": ["out/**/*"],
    "asarUnpack": ["**/node_modules/better-sqlite3/**"],
    "npmRebuild": false,
    "win": { "target": "dir" }
  }
}
