# Postgres (Docker). OWNER roda migrações; o runtime usa o role app (sem UPDATE/DELETE fiscal).
# Use 127.0.0.1 (não localhost) — no Windows+Docker Desktop o localhost pode resolver
# para IPv6 e o engine do Prisma falhar (P1001).
DATABASE_URL_OWNER="postgresql://gelato_owner:owner_pw@127.0.0.1:5432/gelato?schema=public"
DATABASE_URL="postgresql://gelato_app:app_pw@127.0.0.1:5432/gelato?schema=public"

# Auth
JWT_SECRET="dev-secret-change-me"

# fiskaly SIGN DE sandbox (TSE) — preencher com credenciais reais do sandbox
FISKALY_BASE_URL="https://kassensichv-middleware.fiskaly.com"
FISKALY_API_KEY=""
FISKALY_API_SECRET=""
FISKALY_TSS_ID=""
