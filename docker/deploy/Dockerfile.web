# Backoffice (/) + PDV pos-web (/pos) buildados + Caddy: TLS automático,
# estáticos e proxy /api/* -> api:3000.
# syntax=docker/dockerfile:1
FROM node:22-bookworm-slim AS builder
RUN corepack enable
WORKDIR /app
# BASE relativa: os apps chamam a API na MESMA origem, em /api (sem CORS).
ARG VITE_API_URL=/api
ENV VITE_API_URL=$VITE_API_URL
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json tsconfig.base.json ./
COPY packages ./packages
COPY apps/backoffice ./apps/backoffice
COPY apps/pos-web ./apps/pos-web
RUN pnpm install --frozen-lockfile --filter @gelato/backoffice... --filter @gelato/pos-web...
RUN pnpm --filter @gelato/backoffice build
# PDV servido no subpath /pos (assets e SW relativos a /pos/)
RUN pnpm --filter @gelato/pos-web exec vite build --base=/pos/

FROM caddy:2-alpine
COPY docker/deploy/Caddyfile /etc/caddy/Caddyfile
COPY --from=builder /app/apps/backoffice/dist /srv
COPY --from=builder /app/apps/pos-web/dist /srv/pos
