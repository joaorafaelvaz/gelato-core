# Backoffice (Vite) buildado + Caddy como edge: TLS automático (Let's Encrypt),
# estáticos do backoffice e proxy /api/* -> api:3000.
# syntax=docker/dockerfile:1
FROM node:22-bookworm-slim AS builder
RUN corepack enable
WORKDIR /app
# BASE relativa: o backoffice chama a API na MESMA origem, em /api (sem CORS).
ARG VITE_API_URL=/api
ENV VITE_API_URL=$VITE_API_URL
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json tsconfig.base.json ./
COPY packages ./packages
COPY apps/backoffice ./apps/backoffice
RUN pnpm install --frozen-lockfile --filter @gelato/backoffice...
RUN pnpm --filter @gelato/backoffice build

FROM caddy:2-alpine
COPY docker/deploy/Caddyfile /etc/caddy/Caddyfile
COPY --from=builder /app/apps/backoffice/dist /srv
