# Vhost para o NGINX EXISTENTE do VPS (modo atrás-de-proxy).
# Copie para /etc/nginx/sites-available/gelato e ative:
#   ln -s /etc/nginx/sites-available/gelato /etc/nginx/sites-enabled/gelato
#   nginx -t && systemctl reload nginx
# Depois deixe o certbot cuidar do TLS (adiciona o bloco 443 + redirect):
#   certbot --nginx -d gelato.linkwise.digital
server {
    listen 80;
    listen [::]:80;
    server_name gelato.linkwise.digital;

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}
