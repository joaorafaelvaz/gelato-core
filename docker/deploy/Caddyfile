{
	email {$ACME_EMAIL}
}

# CADDY_SITE: o domínio (edge, TLS automático) OU ":80" (atrás de um proxy
# existente que termina o TLS — ex. nginx do host).
{$CADDY_SITE} {
	encode gzip

	# API na mesma origem: /api/orders -> api:3000/orders (prefixo removido)
	handle_path /api/* {
		reverse_proxy api:3000
	}

	# SPA do backoffice (rotas por hash; fallback p/ index.html por segurança)
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
