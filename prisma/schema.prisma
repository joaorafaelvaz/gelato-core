// This is your Prisma schema file for gelato-core.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// BASE / MULTI-TENANT
// ============================================================

model Tenant {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  legalName    String?  @map("legal_name")
  taxId        String?  @map("tax_id") // USt-IdNr.
  addressLine1 String?  @map("address_line_1")
  addressLine2 String?  @map("address_line_2")
  zipCode      String?  @map("zip_code")
  city         String?
  country      String   @default("DE")
  phone        String?
  email        String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  betriebsstaetten   Betriebsstaette[]
  users              User[]
  roles              Role[]
  productCategories  ProductCategory[]
  products           Product[]
  ingredients        Ingredient[]
  customers          Customer[]
  campaigns          Campaign[]
  promotions         Promotion[]
  vouchers           Voucher[]
  auditLogs          AuditLog[]
  checklistTemplates ChecklistTemplate[]

  @@map("tenants")
}

model Betriebsstaette {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  name         String
  slug         String
  finanzamtNr  String?  @map("finanzamt_nr")
  addressLine1 String?  @map("address_line_1")
  addressLine2 String?  @map("address_line_2")
  zipCode      String?  @map("zip_code")
  city         String?
  country      String   @default("DE")
  phone        String?
  email        String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kassen        Kasse[]
  users         BetriebsstaetteUser[]
  shifts        Shift[]
  stockItems    StockItem[]
  checklistRuns ChecklistRun[]
  customers     Customer[]

  @@unique([tenantId, slug])
  @@map("betriebsstaetten")
}

model Kasse {
  id                String   @id @default(uuid())
  betriebsstaetteId String   @map("betriebsstaette_id")
  name              String
  serialNumber      String?  @map("serial_number")
  location          String?
  elsterStatus      String   @default("pending") @map("elster_status")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  betriebsstaette Betriebsstaette @relation(fields: [betriebsstaetteId], references: [id], onDelete: Cascade)
  tseClient       TseClient?
  shifts          Shift[]
  orders          Order[]
  zReports        ZReport[]
  outboxEvents    OutboxEvent[]

  @@unique([betriebsstaetteId, name])
  @@map("kassen")
}

// ============================================================
// AUTH / RBAC
// ============================================================

model User {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  email        String
  passwordHash String    @map("password_hash")
  pinHash      String?   @map("pin_hash") // quick login on POS terminal
  name         String
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles        UserRole[]
  betriebsstaetten BetriebsstaetteUser[]
  shifts           Shift[]
  auditLogs        AuditLog[]
  stockMovements   StockMovement[]
  checklistRuns    ChecklistRun[]

  @@unique([tenantId, email])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  key         String // operator, lagerist, admin
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([tenantId, key])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique // pos.sale.create, admin.users, etc.
  name        String
  description String?
  category    String? // pos, stock, admin, etc.
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model BetriebsstaetteUser {
  betriebsstaetteId String   @map("betriebsstaette_id")
  userId            String   @map("user_id")
  createdAt         DateTime @default(now()) @map("created_at")

  betriebsstaette Betriebsstaette @relation(fields: [betriebsstaetteId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([betriebsstaetteId, userId])
  @@map("betriebsstaette_users")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  userId     String?  @map("user_id")
  action     String // e.g. pos.sale.void, admin.tse.configure
  entity     String // table / domain entity
  entityId   String?  @map("entity_id")
  payload    Json?
  ipAddress  String?  @map("ip_address")
  deviceInfo String?  @map("device_info")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, action])
  @@index([tenantId, entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
  @@ignore // managed via raw SQL triggers + append-only policy
}

// ============================================================
// APPEND-ONLY FISCAL TABLES (GoBD)
// ============================================================
// The following tables are protected at the database level by
// migration scripts: UPDATE/DELETE are rejected for finalized
// fiscal records. They intentionally have no updatedAt.



// ============================================================
// TSE (Technische Sicherheitseinrichtung)
// ============================================================

model TseClient {
  id               String    @id @default(uuid())
  kasseId          String    @unique @map("kasse_id")
  provider         String // fiskaly, swissbit
  serialNumber     String    @map("serial_number")
  publicKey        String?   @map("public_key")
  apiUrl           String?   @map("api_url")
  credentials      Json? // encrypted / structured credentials
  registeredAt     DateTime? @map("registered_at")
  deregistrationAt DateTime? @map("deregistration_at")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  kasse Kasse @relation(fields: [kasseId], references: [id], onDelete: Cascade)

  @@map("tse_clients")
}

// ============================================================
// FISCAL / POS
// ============================================================

enum OrderMode {
  IM_HAUS
  AUSSER_HAUS
}

enum OrderStatus {
  OPEN
  HOLD
  CLOSED
  VOIDED
}

model Shift {
  id           String    @id @default(uuid())
  kasseId      String    @map("kasse_id")
  userId       String    @map("user_id")
  openedAt     DateTime  @default(now()) @map("opened_at")
  closedAt     DateTime? @map("closed_at")
  openingFloat Decimal   @default(0) @map("opening_float") @db.Decimal(12, 2)
  closingCount Decimal?  @map("closing_count") @db.Decimal(12, 2)
  zReportId    String?   @unique @map("z_report_id")
  createdAt    DateTime  @default(now()) @map("created_at")

  kasse             Kasse            @relation(fields: [kasseId], references: [id], onDelete: Cascade)
  user              User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  orders            Order[]
  zReport           ZReport?         @relation(fields: [zReportId], references: [id])
  betriebsstaette   Betriebsstaette? @relation(fields: [betriebsstaetteId], references: [id])
  betriebsstaetteId String?

  @@map("shifts")
}

model Order {
  id         String      @id @default(uuid())
  kasseId    String      @map("kasse_id")
  shiftId    String      @map("shift_id")
  mode       OrderMode   @default(IM_HAUS)
  tableId    String?     @map("table_id")
  status     OrderStatus @default(OPEN)
  customerId String?     @map("customer_id")
  totalNet   Decimal     @default(0) @map("total_net") @db.Decimal(12, 2)
  totalMwst  Decimal     @default(0) @map("total_mwst") @db.Decimal(12, 2)
  totalGross Decimal     @default(0) @map("total_gross") @db.Decimal(12, 2)
  createdAt  DateTime    @default(now()) @map("created_at")

  kasse          Kasse           @relation(fields: [kasseId], references: [id], onDelete: Cascade)
  shift          Shift           @relation(fields: [shiftId], references: [id], onDelete: Restrict)
  items          OrderItem[]
  payments       Payment[]
  receipt        Receipt?
  storno         OrderStorno?
  tseTx          TseTransaction?
  stockMovements StockMovement[]
  customer       Customer?       @relation(fields: [customerId], references: [id])

  @@index([kasseId, createdAt])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  productId  String   @map("product_id")
  variantId  String?  @map("variant_id")
  qty        Decimal  @default(1) @db.Decimal(10, 3)
  unitPrice  Decimal  @map("unit_price") @db.Decimal(12, 2)
  unitNet    Decimal  @map("unit_net") @db.Decimal(12, 2)
  mwstRate   Decimal  @map("mwst_rate") @db.Decimal(5, 2)
  modifiers  Json? // selected modifiers & price deltas
  totalNet   Decimal  @map("total_net") @db.Decimal(12, 2)
  totalGross Decimal  @map("total_gross") @db.Decimal(12, 2)
  createdAt  DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model OrderStorno {
  id              String   @id @default(uuid())
  originalOrderId String   @unique @map("original_order_id")
  reason          String
  userId          String   @map("user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  originalOrder Order @relation(fields: [originalOrderId], references: [id], onDelete: Cascade)

  @@map("order_stornos")
}

enum PaymentMethod {
  CASH
  CARD
  VOUCHER
  OTHER
}

model Payment {
  id        String        @id @default(uuid())
  orderId   String        @map("order_id")
  method    PaymentMethod
  amount    Decimal       @db.Decimal(12, 2)
  reference String?
  createdAt DateTime      @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

enum ReceiptFormat {
  PRINT
  DIGITAL
}

model Receipt {
  id            String        @id @default(uuid())
  orderId       String        @unique @map("order_id")
  format        ReceiptFormat @default(PRINT)
  tseSignature  Json?         @map("tse_signature")
  qrPayload     String?       @map("qr_payload")
  clientEventId String?       @map("client_event_id") // for idempotent sync
  issuedAt      DateTime      @default(now()) @map("issued_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("receipts")
}

model TseTransaction {
  id               String    @id @default(uuid())
  orderId          String    @unique @map("order_id")
  tseClientId      String    @map("tse_client_id")
  txNumber         String    @map("tx_number")
  signatureCounter String?   @map("signature_counter")
  signatureValue   String?   @map("signature_value")
  logTime          DateTime  @default(now()) @map("log_time")
  processType      String    @map("process_type")
  startTime        DateTime  @map("start_time")
  finishTime       DateTime? @map("finish_time")
  errorMessage     String?   @map("error_message")
  isAusfall        Boolean   @default(false) @map("is_ausfall") // TSE-Ausfall documented
  createdAt        DateTime  @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("tse_transactions")
}

model ZReport {
  id          String   @id @default(uuid())
  kasseId     String   @map("kasse_id")
  seqNr       Int      @map("seq_nr")
  businessDay DateTime @map("business_day") @db.Date
  totals      Json
  generatedAt DateTime @default(now()) @map("generated_at")

  kasse Kasse  @relation(fields: [kasseId], references: [id], onDelete: Cascade)
  shift Shift?

  @@unique([kasseId, seqNr])
  @@map("z_reports")
}

// ============================================================
// PRODUCTS & RECIPES
// ============================================================

model ProductCategory {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  parentId  String?  @map("parent_id")
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  color     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryHierarchy")
  products Product[]

  @@map("product_categories")
}

enum ProductType {
  VENDAVEL
  INSUMO
  SEMI_ACABADO
}

model Product {
  id              String      @id @default(uuid())
  tenantId        String      @map("tenant_id")
  categoryId      String?     @map("category_id")
  type            ProductType @default(VENDAVEL)
  name            String
  description     String?
  basePrice       Decimal?    @map("base_price") @db.Decimal(12, 2)
  mwstImHaus      Decimal     @map("mwst_im_haus") @db.Decimal(5, 2)
  mwstAusserHaus  Decimal     @map("mwst_ausser_haus") @db.Decimal(5, 2)
  gtin            String?
  allergens       Json?
  nutritionalInfo Json?       @map("nutritional_info")
  isActive        Boolean     @default(true) @map("is_active")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category  ProductCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  variants  ProductVariant[]
  modifiers ProductModifier[]
  recipe    Recipe?

  @@map("products")
}

model ProductVariant {
  id         String  @id @default(uuid())
  productId  String  @map("product_id")
  name       String
  priceDelta Decimal @default(0) @map("price_delta") @db.Decimal(12, 2)
  sortOrder  Int     @default(0) @map("sort_order")
  isActive   Boolean @default(true) @map("is_active")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}

model ProductModifier {
  id         String  @id @default(uuid())
  productId  String  @map("product_id")
  name       String
  priceDelta Decimal @default(0) @map("price_delta") @db.Decimal(12, 2)
  groupKey   String? @map("group_key") // for exclusive option groups
  min        Int     @default(0)
  max        Int     @default(1)
  isActive   Boolean @default(true) @map("is_active")
  sortOrder  Int     @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_modifiers")
}

model Recipe {
  id        String   @id @default(uuid())
  productId String   @unique @map("product_id")
  active    Boolean  @default(false)
  yieldQty  Decimal  @map("yield_qty") @db.Decimal(12, 3)
  yieldUnit String   @map("yield_unit")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product     Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredients RecipeIngredient[]

  @@map("recipes")
}

model RecipeIngredient {
  id             String   @id @default(uuid())
  recipeId       String   @map("recipe_id")
  ingredientId   String   @map("ingredient_id")
  qty            Decimal  @db.Decimal(12, 3)
  unit           String
  costAtCreation Decimal? @map("cost_at_creation") @db.Decimal(12, 4)

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@map("recipe_ingredients")
}

// ============================================================
// STOCK
// ============================================================

model Ingredient {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  baseUnit    String   @map("base_unit") // g, ml, un
  description String?
  avgCost     Decimal? @map("avg_cost") @db.Decimal(12, 4)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stockItems   StockItem[]
  recipeUsages RecipeIngredient[]

  @@map("ingredients")
}

model StockItem {
  id                String   @id @default(uuid())
  ingredientId      String   @map("ingredient_id")
  betriebsstaetteId String   @map("betriebsstaette_id")
  qtyBase           Decimal  @default(0) @map("qty_base") @db.Decimal(15, 3)
  mindestbestand    Decimal  @default(0) @db.Decimal(15, 3)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  ingredient      Ingredient      @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  betriebsstaette Betriebsstaette @relation(fields: [betriebsstaetteId], references: [id], onDelete: Cascade)
  movements       StockMovement[]

  @@unique([ingredientId, betriebsstaetteId])
  @@map("stock_items")
}

enum StockMovementType {
  MANUAL_ADJUST
  RECEIVING
  SALE_CONSUMPTION
  WASTE
  PRODUCTION
  TRANSFER
  COUNT
}

model StockMovement {
  id          String            @id @default(uuid())
  stockItemId String            @map("stock_item_id")
  type        StockMovementType
  qtyBase     Decimal           @map("qty_base") @db.Decimal(15, 3) // positive or negative
  reason      String?
  refOrderId  String?           @map("ref_order_id")
  userId      String?           @map("user_id")
  createdAt   DateTime          @default(now()) @map("created_at")

  stockItem StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  order     Order?    @relation(fields: [refOrderId], references: [id], onDelete: SetNull)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("stock_movements")
}

// ============================================================
// CHECKLIST / HACCP
// ============================================================

enum ChecklistRecurrence {
  PER_SHIFT
  DAILY
  WEEKLY
  MONTHLY
  EVENT
}

model ChecklistTemplate {
  id           String              @id @default(uuid())
  tenantId     String              @map("tenant_id")
  name         String
  recurrence   ChecklistRecurrence @default(DAILY)
  triggerEvent String?             @map("trigger_event") // open_shift, close_shift, cleaning, etc.
  isActive     Boolean             @default(true) @map("is_active")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tasks  ChecklistTask[]
  runs   ChecklistRun[]

  @@map("checklist_templates")
}

enum ChecklistTaskType {
  BOOL
  NUMERIC
  TEXT
  PHOTO
  SIGNATURE
}

model ChecklistTask {
  id         String            @id @default(uuid())
  templateId String            @map("template_id")
  label      String
  type       ChecklistTaskType @default(BOOL)
  validMin   Decimal?          @map("valid_min") @db.Decimal(10, 2)
  validMax   Decimal?          @map("valid_max") @db.Decimal(10, 2)
  sortOrder  Int               @default(0) @map("sort_order")
  isActive   Boolean           @default(true) @map("is_active")

  template ChecklistTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  results  ChecklistTaskResult[]

  @@map("checklist_tasks")
}

model ChecklistRun {
  id                String    @id @default(uuid())
  templateId        String    @map("template_id")
  betriebsstaetteId String    @map("betriebsstaette_id")
  userId            String    @map("user_id")
  startedAt         DateTime  @default(now()) @map("started_at")
  completedAt       DateTime? @map("completed_at")

  template        ChecklistTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  betriebsstaette Betriebsstaette       @relation(fields: [betriebsstaetteId], references: [id], onDelete: Cascade)
  user            User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  results         ChecklistTaskResult[]

  @@map("checklist_runs")
}

model ChecklistTaskResult {
  id               String   @id @default(uuid())
  runId            String   @map("run_id")
  taskId           String   @map("task_id")
  value            Json?
  ok               Boolean?
  correctiveAction String?  @map("corrective_action")
  createdAt        DateTime @default(now()) @map("created_at")

  run  ChecklistRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  task ChecklistTask @relation(fields: [taskId], references: [id], onDelete: Restrict)

  @@map("checklist_task_results")
}

// ============================================================
// MARKETING
// ============================================================

model Customer {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  betriebsstaetteId String?   @map("betriebsstaette_id")
  name              String?
  contact           Json? // email, phone, address
  consent           Json? // DSGVO consent log
  birthDate         DateTime? @map("birth_date") @db.Date
  notes             String?
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  betriebsstaette Betriebsstaette? @relation(fields: [betriebsstaetteId], references: [id], onDelete: SetNull)
  loyaltyAccount  LoyaltyAccount?
  orders          Order[]

  @@map("customers")
}

model LoyaltyAccount {
  id         String   @id @default(uuid())
  customerId String   @unique @map("customer_id")
  points     Int      @default(0)
  stamps     Int      @default(0)
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("loyalty_accounts")
}

enum VoucherType {
  FIXED_AMOUNT
  PERCENTAGE
  PRODUCT
}

model Voucher {
  id        String      @id @default(uuid())
  tenantId  String      @map("tenant_id")
  code      String
  type      VoucherType @default(FIXED_AMOUNT)
  value     Decimal     @db.Decimal(12, 2)
  validFrom DateTime    @map("valid_from")
  validTo   DateTime?   @map("valid_to")
  maxUses   Int?        @map("max_uses")
  usedCount Int         @default(0) @map("used_count")
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@map("vouchers")
}

model Promotion {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  name       String
  rule       Json // structured rule definition
  activeFrom DateTime  @map("active_from")
  activeTo   DateTime? @map("active_to")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("promotions")
}

enum CampaignChannel {
  EMAIL
  WHATSAPP
  SMS
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
  CANCELLED
}

model Campaign {
  id          String          @id @default(uuid())
  tenantId    String          @map("tenant_id")
  name        String
  channel     CampaignChannel @default(EMAIL)
  segment     Json? // filter definition
  scheduledAt DateTime?       @map("scheduled_at")
  status      CampaignStatus  @default(DRAFT)
  content     Json?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("campaigns")
}

// ============================================================
// SYNC / OUTBOX
// ============================================================

// This model lives both in local SQLite (POS terminal)
// and optionally in PostgreSQL server as inbound queue log.
model OutboxEvent {
  id            String    @id @default(uuid())
  clientEventId String    @unique @map("client_event_id")
  kasseId       String?   @map("kasse_id")
  entity        String
  action        String
  payload       Json
  status        String    @default("pending") // pending, delivered, failed
  retryCount    Int       @default(0) @map("retry_count")
  error         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  deliveredAt   DateTime? @map("delivered_at")

  kasse Kasse? @relation(fields: [kasseId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([kasseId, clientEventId])
  @@map("outbox_events")
}
